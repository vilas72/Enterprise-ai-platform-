<mxfile host="app.diagrams.net">
  <diagram id="sequence" name="Generation Sequence">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" page="1" pageWidth="1169" pageHeight="827">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="caller" value="Caller" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="service" value="AI Service" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="provider" value="AIProvider" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="100" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="request" value="generate(prompt)" edge="1" parent="1" source="caller" target="service"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="generate" value="generate(prompt)" edge="1" parent="1" source="service" target="provider"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
